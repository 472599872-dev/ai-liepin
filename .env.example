# 不要把真实账号密码提交到 Git。复制为 .env 后在本机填写。
LIEPIN_USERNAME=
LIEPIN_PASSWORD=

# 可选：用于更稳定的简历评分和问候语生成。留空时使用本地规则评分。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# 千问 DashScope OpenAI-compatible 配置。配置后系统内 LLM 优先使用千问。
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 运行安全开关：true 时不实际点击发送问候。
DRY_RUN=true
